---
---

<header class="fixed top-0 left-0 right-0 z-50 glass transition-all duration-200">
  <nav class="mx-auto max-w-5xl px-4 xl:px-8">
    <div class="flex items-center justify-between py-4">
      <a href="/" class="flex-shrink-0">
        <img src="https://www.tazamaafricasafari.com/assets/images/logos/tazama-gold.png" alt="Tazama Africa" class="h-12" />
      </a>
      
      <div class="hidden md:flex items-center gap-8">
        <a href="#contact" class="rounded-full bg-[#A87133] px-6 py-2 font-raleway font-semibold text-white transition-colors hover:bg-primary/90">
          Plan My Trip
        </a>
        <a href="/contact" class="font-raleway font-medium text-stone-800 transition-colors hover:text-primary relative group">
          Contact Us
          <span class="absolute bottom-0 left-0 h-0.5 w-0 bg-primary transition-all duration-200 group-hover:w-full"></span>
        </a>
      </div>
      
      <button id="menu-toggle" class="md:hidden p-2" aria-label="Toggle menu">
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu">
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>
  
  <div id="mobile-menu" class="fixed inset-0 z-40 hidden bg-darker/95 backdrop-blur-lg">
    <div class="flex flex-col items-center justify-center h-full gap-8 text-white">
      <a href="/" class="text-2xl font-raleway font-semibold hover:text-primary transition-colors">Home</a>
      <a href="#about" class="text-2xl font-raleway font-semibold hover:text-primary transition-colors">About</a>
      <a href="#destinations" class="text-2xl font-raleway font-semibold hover:text-primary transition-colors">Destinations</a>
      <a href="#tours" class="text-2xl font-raleway font-semibold hover:text-primary transition-colors">Tours</a>
      <a href="#lodges" class="text-2xl font-raleway font-semibold hover:text-primary transition-colors">Lodges</a>
      <a href="#contact" class="text-2xl font-raleway font-semibold hover:text-primary transition-colors">Contact</a>
      <a href="#contact" class="mt-4 rounded-full bg-[#A87133] px-8 py-3 text-lg font-raleway font-semibold text-white transition-colors hover:bg-primary/90">
        Plan My Trip
      </a>
    </div>
  </div>
</header>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  let menuOpen = false;
  
  menuToggle?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    mobileMenu?.classList.toggle('hidden');
    document.body.style.overflow = menuOpen ? 'hidden' : '';
  });
  
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menuOpen = false;
      mobileMenu?.classList.add('hidden');
      document.body.style.overflow = '';
    });
  });
</script>
