---
import { getCollection, getEntry } from 'astro:content';
const homepageEntry = await getEntry('homepage', 'homepage');
const homepage = homepageEntry.data;
const partners = (await getCollection('partners')).sort(
  (a, b) => a.data.order - b.data.order
);
const marqueePartners = [...partners, ...partners, ...partners, ...partners];
---

<section class="bg-lighter py-16 overflow-hidden">
  <div class="mx-auto max-w-5xl px-4 xl:px-8 mb-10">
    <h2 class="text-3xl font-raleway font-bold text-stone-800 text-center mb-4">{homepage.partners_heading}</h2>
    <p class="text-stone-600 text-center max-w-2xl mx-auto">{homepage.partners_text}</p>
  </div>
  
  <div class="relative flex overflow-hidden">
    <div class="flex animate-marquee items-center gap-12 md:gap-16">
      {marqueePartners.map((partner) => (
        <a href={partner.data.link} target={partner.data.link.startsWith('http') ? '_blank' : undefined} rel={partner.data.link.startsWith('http') ? 'noopener noreferrer' : undefined} class="flex-shrink-0 group">
          <img src={partner.data.image} alt={`${partner.data.name} Logo`} class="h-12 md:h-16 w-auto object-contain opacity-70 group-hover:opacity-100 transition-all duration-300" loading="lazy" decoding="async" />
        </a>
      ))}
    </div>
  </div>
</section>
