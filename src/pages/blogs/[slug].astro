---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title={`${post.data.title} - Tazama Africa Safaris`}>
  <article>
    <div class="relative h-[50vh] md:h-[60vh]">
      <img
        src={post.data.thumbnail ? `https://www.tazamaafricasafari.com/_next/image?url=${encodeURIComponent(post.data.thumbnail)}&w=1920&q=80` : '/assets/images/gallery/tanzania.jpg'}
        alt={post.data.title}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-stone-900 via-stone-900/50 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 pb-8">
        <div class="container mx-auto px-4">
          <a href="/blogs" class="inline-flex items-center gap-2 text-white/80 hover:text-gold transition-colors mb-6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Blog
          </a>
          <span class="inline-block px-3 py-1 bg-gold text-white text-xs font-medium uppercase tracking-wide rounded mb-4">
            {post.data.category}
          </span>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-serif text-white max-w-4xl">
            {post.data.title}
          </h1>
        </div>
      </div>
    </div>

    <div class="py-12 md:py-16 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center gap-4 text-stone-500 mb-8 pb-8 border-b border-stone-200">
            <time datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date)}
            </time>
            <span class="w-1 h-1 bg-stone-300 rounded-full"></span>
            <span>{post.data.author}</span>
          </div>

          <div class="prose prose-lg prose-stone max-w-none prose-headings:font-serif prose-headings:text-stone-800 prose-a:text-gold prose-a:no-underline hover:prose-a:underline prose-img:rounded-lg">
            <Content />
          </div>

          <div class="mt-12 pt-8 border-t border-stone-200">
            <a href="/blogs" class="inline-flex items-center gap-2 text-gold hover:text-gold-dark transition-colors font-medium">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
              Back to All Posts
            </a>
          </div>
        </div>
      </div>
    </div>
  </article>
</Layout>