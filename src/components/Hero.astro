<section class="relative h-screen overflow-hidden">
  <video autoplay muted loop playsinline class="absolute inset-0 h-full w-full object-cover">
    <source src="https://res.cloudinary.com/drhl0yu7y/video/upload/v1764753833/tazama-video_ijznqm.mp4" type="video/mp4">
  </video>
  
  <div class="absolute inset-0 bg-black/40"></div>
  
  <div class="relative z-10 flex flex-col items-center justify-center h-full px-4 text-center text-white">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-raleway font-bold mb-6 text-shadow">Your Next Adventure Awaits</h1>
    <p class="text-lg md:text-xl font-poppins font-light mb-4 text-shadow">connect, celebrate & create memories</p>
  </div>
  
  <div class="absolute bottom-8 left-0 right-0 z-10 mx-auto max-w-5xl px-4 xl:px-8">
    <div class="grid gap-4 md:grid-cols-3">
      <a href="/safaris" class="group relative overflow-hidden rounded-2xl aspect-[4/5]">
        <img src="https://images.unsplash.com/photo-1695787841479-614715857c28?q=80&w=870&auto=format&fit=crop" alt="Safaris" class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-5 text-white">
          <h3 class="text-xl font-raleway font-semibold mb-1">Safaris</h3>
          <p class="text-xs text-stone-300 mb-3">Serengeti • Ngorongoro • Tarangire</p>
          <span class="inline-block text-sm text-primary font-raleway font-semibold group-hover:underline">Discover more</span>
        </div>
      </a>
      
      <a href="/trekking" class="group relative overflow-hidden rounded-2xl aspect-[4/5]">
        <img src="https://images.pexels.com/photos/2101088/pexels-photo-2101088.jpeg" alt="Trekking" class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-5 text-white">
          <h3 class="text-xl font-raleway font-semibold mb-1">Trekking</h3>
          <p class="text-xs text-stone-300 mb-3">Kilimanjaro • Meru • Gorilla Trekking</p>
          <span class="inline-block text-sm text-primary font-raleway font-semibold group-hover:underline">Discover more</span>
        </div>
      </a>
      
      <a href="/zanzibar" class="group relative overflow-hidden rounded-2xl aspect-[4/5]">
        <img src="https://images.unsplash.com/photo-1621583628955-42fbc37bf424?q=80&w=435&auto=format&fit=crop" alt="Beach Holidays" class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-5 text-white">
          <h3 class="text-xl font-raleway font-semibold mb-1">Beach Holidays</h3>
          <p class="text-xs text-stone-300 mb-3">Zanzibar • Spice Island • Stone Town</p>
          <span class="inline-block text-sm text-primary font-raleway font-semibold group-hover:underline">Discover more</span>
        </div>
      </a>
    </div>
  </div>
</section>

