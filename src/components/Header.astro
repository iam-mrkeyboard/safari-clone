---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import logoImage from '../assets/uploads/logo-tazama-gold.png';
const site = await getEntry('site', 'settings');
const whatsNumber = site.data.whatsapp_number;
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="mx-auto max-w-7xl px-4 xl:px-8">
    <nav class="flex items-center justify-between py-4">
      <a href="/" class="flex-shrink-0 z-50 relative">
        <Image src={logoImage} alt="Tazama Africa" class="h-10 md:h-12 w-auto transition-all duration-500" loading="eager" />
      </a>
      
      <div class="hidden lg:flex items-center gap-1">
        <a href="/" class="nav-link px-4 py-2 font-raleway text-sm font-medium text-white/90 hover:text-white transition-colors duration-200 rounded-full">Home</a>
        
        <div class="relative group">
          <button class="nav-link flex items-center gap-1 px-4 py-2 font-raleway text-sm font-medium text-white/90 hover:text-white transition-colors duration-200 rounded-full">
            Experiences
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300">
            <div class="w-56 bg-white rounded-2xl shadow-2xl shadow-black/10 border border-stone-100 p-2">
              <a href="/safaris" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-primary/5 transition-colors group/item">
                <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary group-hover/item:bg-primary group-hover/item:text-white transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
                <div>
                  <span class="block text-sm font-raleway font-semibold text-stone-800">Safaris</span>
                  <span class="block text-xs text-stone-400">Wildlife adventures</span>
                </div>
              </a>
              <a href="/kilimanjaro" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-primary/5 transition-colors group/item">
                <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary group-hover/item:bg-primary group-hover/item:text-white transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>
                </div>
                <div>
                  <span class="block text-sm font-raleway font-semibold text-stone-800">Kilimanjaro</span>
                  <span class="block text-xs text-stone-400">Mountain treks</span>
                </div>
              </a>
              <a href="/tours" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-primary/5 transition-colors group/item">
                <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary group-hover/item:bg-primary group-hover/item:text-white transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
                </div>
                <div>
                  <span class="block text-sm font-raleway font-semibold text-stone-800">All Tours</span>
                  <span class="block text-xs text-stone-400">View complete list</span>
                </div>
              </a>
            </div>
          </div>
        </div>
        
        <a href="/about" class="nav-link px-4 py-2 font-raleway text-sm font-medium text-white/90 hover:text-white transition-colors duration-200 rounded-full">About</a>
        <a href="/blogs" class="nav-link px-4 py-2 font-raleway text-sm font-medium text-white/90 hover:text-white transition-colors duration-200 rounded-full">Blog</a>
        <a href="/contact" class="nav-link px-4 py-2 font-raleway text-sm font-medium text-white/90 hover:text-white transition-colors duration-200 rounded-full">Contact</a>
      </div>
      
      <div class="hidden lg:flex items-center gap-3">
        <a href={`https://wa.me/${whatsNumber.replace(/\+/g, '')}`} target="_blank" rel="noopener noreferrer" class="nav-link w-10 h-10 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center text-white/90 hover:text-white hover:bg-white/20 transition-all duration-200" aria-label="WhatsApp">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        </a>
        <a href="#contact" class="px-6 py-2.5 bg-primary text-white font-raleway text-sm font-semibold rounded-full hover:bg-primary-dark transition-all duration-200 shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30">
          Plan My Trip
        </a>
      </div>
      
      <button id="menu-toggle-mobile" class="lg:hidden relative z-50 w-10 h-10 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center text-white hover:bg-white/20 transition-all duration-200" aria-label="Toggle menu">
        <svg id="menu-icon-open" class="w-5 h-5 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
        <svg id="menu-icon-close" class="w-5 h-5 absolute transition-all duration-300 opacity-0 scale-75" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"></line><line x1="6" x2="18" y1="6" y2="18"></line></svg>
      </button>
    </nav>
  </div>
  
  <div id="mobile-menu" class="fixed inset-0 z-40 lg:hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300" id="mobile-menu-overlay"></div>
    <div class="absolute right-0 top-0 bottom-0 w-80 max-w-[85vw] bg-white shadow-2xl translate-x-full transition-transform duration-300 ease-out" id="mobile-menu-panel">
      <div class="flex flex-col h-full pt-20 pb-8 px-6 overflow-y-auto">
        <div class="flex flex-col gap-1">
          <a href="/" class="mobile-nav-link px-4 py-3 font-raleway text-base font-semibold text-stone-800 rounded-xl hover:bg-primary/5 transition-colors">Home</a>
          <a href="/safaris" class="mobile-nav-link px-4 py-3 font-raleway text-base font-semibold text-stone-800 rounded-xl hover:bg-primary/5 transition-colors">Safaris</a>
          <a href="/kilimanjaro" class="mobile-nav-link px-4 py-3 font-raleway text-base font-semibold text-stone-800 rounded-xl hover:bg-primary/5 transition-colors">Kilimanjaro</a>
          <a href="/tours" class="mobile-nav-link px-4 py-3 font-raleway text-base font-semibold text-stone-800 rounded-xl hover:bg-primary/5 transition-colors">All Tours</a>
          <a href="/about" class="mobile-nav-link px-4 py-3 font-raleway text-base font-semibold text-stone-800 rounded-xl hover:bg-primary/5 transition-colors">About</a>
          <a href="/blogs" class="mobile-nav-link px-4 py-3 font-raleway text-base font-semibold text-stone-800 rounded-xl hover:bg-primary/5 transition-colors">Blog</a>
          <a href="/contact" class="mobile-nav-link px-4 py-3 font-raleway text-base font-semibold text-stone-800 rounded-xl hover:bg-primary/5 transition-colors">Contact</a>
        </div>
        
        <div class="mt-auto pt-8 border-t border-stone-100">
          <a href="https://wa.me/255754922334" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-4 py-3 text-stone-500 hover:text-primary transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            <span class="font-raleway font-medium">+255 754 922 334</span>
          </a>
          <div class="flex gap-3 mt-6">
            <a href="#contact" class="flex-1 px-6 py-3 bg-primary text-white font-raleway text-sm font-semibold rounded-full text-center hover:bg-primary-dark transition-colors shadow-lg shadow-primary/20">
              Plan My Trip
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  const menuToggleMobile = document.getElementById('menu-toggle-mobile');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
  const mobileMenuPanel = document.getElementById('mobile-menu-panel');
  let menuOpen = false;
  
  function toggleMenu() {
    menuOpen = !menuOpen;
    if (menuOpen) {
      mobileMenu?.classList.remove('hidden');
      requestAnimationFrame(() => {
        mobileMenuOverlay?.classList.remove('opacity-0');
        mobileMenuPanel?.classList.remove('translate-x-full');
        menuIconOpen?.classList.add('opacity-0', 'scale-75');
        menuIconClose?.classList.remove('opacity-0', 'scale-75');
      });
    } else {
      mobileMenuOverlay?.classList.add('opacity-0');
      mobileMenuPanel?.classList.add('translate-x-full');
      menuIconOpen?.classList.remove('opacity-0', 'scale-75');
      menuIconClose?.classList.add('opacity-0', 'scale-75');
      setTimeout(() => mobileMenu?.classList.add('hidden'), 300);
    }
    document.body.style.overflow = menuOpen ? 'hidden' : '';
  }
  
  menuToggleMobile?.addEventListener('click', toggleMenu);
  mobileMenuOverlay?.addEventListener('click', toggleMenu);
  
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      if (menuOpen) toggleMenu();
    });
  });
  
  function updateHeader() {
    const menuBtn = document.getElementById('menu-toggle-mobile');
    if (window.scrollY > 50) {
      header?.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-sm');
      document.querySelectorAll('.nav-link').forEach(link => {
        link.classList.remove('text-white/90', 'hover:text-white');
        link.classList.add('text-stone-600', 'hover:text-primary');
      });
      menuBtn?.classList.remove('text-white', 'bg-white/10', 'hover:bg-white/20');
      menuBtn?.classList.add('text-stone-600', 'bg-stone-100', 'hover:bg-stone-200');
    } else {
      header?.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-sm');
      document.querySelectorAll('.nav-link').forEach(link => {
        link.classList.add('text-white/90', 'hover:text-white');
        link.classList.remove('text-stone-600', 'hover:text-primary');
      });
      menuBtn?.classList.add('text-white', 'bg-white/10', 'hover:bg-white/20');
      menuBtn?.classList.remove('text-stone-600', 'bg-stone-100', 'hover:bg-stone-200');
    }
  }
  
  updateHeader();
  window.addEventListener('scroll', updateHeader);
</script>
