---

<section id="destinations" class="bg-dark py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4 xl:px-8">
    <div class="text-center text-white mb-16">
      <h2 class="text-3xl md:text-4xl font-raleway font-bold mb-6">Explore East Africa, The Tazama Way</h2>
      <p class="text-stone-400 max-w-2xl mx-auto">Our expertise spans all four corners of East Africa. Whether you're tracking gorillas, chasing the Great Migration, or unwinding on pristine coastlines, Tazama crafts fully personalized itineraries shaped around you.</p>
      <p class="text-stone-400 mt-4">Click on any destination below and begin your journey.</p>
    </div>
    
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 auto-rows-[220px]">
      <a href="/safaris" class="group relative overflow-hidden rounded-2xl row-span-2 card-lift">
        <img src="https://images.unsplash.com/photo-1741850826371-b37047bece5d?q=80&w=600&auto=format&fit=crop" alt="Tanzania" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <h3 class="text-3xl font-raleway font-bold text-white">Tanzania</h3>
        </div>
      </a>
      
      <a href="/east-africa/uganda" class="group relative overflow-hidden rounded-2xl card-lift">
        <img src="/assets/images/gallery/chimps.webp" alt="Uganda" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <h3 class="text-xl font-raleway font-semibold text-white">Uganda</h3>
        </div>
      </a>
      
      <a href="/east-africa/rwanda" class="group relative overflow-hidden rounded-2xl card-lift">
        <img src="/assets/images/gallery/rwanda/rwanda.jpg" alt="Rwanda" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <h3 class="text-xl font-raleway font-semibold text-white">Rwanda</h3>
        </div>
      </a>
      
      <a href="/east-africa/kenya" class="group relative overflow-hidden rounded-2xl col-span-2 lg:col-span-1 card-lift">
        <img src="/assets/images/gallery/kenya/kenya.jpg" alt="Kenya" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <h3 class="text-xl font-raleway font-semibold text-white">Kenya</h3>
        </div>
      </a>
    </div>
  </div>
</section>