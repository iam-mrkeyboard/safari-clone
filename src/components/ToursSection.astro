---
---

<section id="tours" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4 xl:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-raleway font-bold text-stone-800 mb-4">Authentic & Timeless Adventures</h2>
      <p class="text-stone-600 max-w-2xl mx-auto">Start exploring our sample itineraries and see where an adventure with Tazama Africa can take you.</p>
    </div>
    
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      <a href="/tours/2-day-tarangire-and-ngorongoro-safari" class="group relative overflow-hidden rounded-2xl bg-lighter shadow-lg card-lift">
        <div class="relative overflow-hidden aspect-[16/10]">
          <img src="https://cdn.sanity.io/images/oot9i5yy/production/5330544f7ebacf5cc451a5ad3d1b9f2e2c241fa7-1920x1080.jpg" alt="Baobab tree in Tarangire" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
          <span class="absolute top-4 left-4 bg-primary text-white text-xs font-semibold px-3 py-1 rounded-full">Popular</span>
        </div>
        <div class="p-6">
          <h3 class="text-lg font-raleway font-semibold text-stone-800 mb-2">2-Day Tarangire & Ngorongoro Safari</h3>
          <div class="flex items-center gap-2 text-sm text-stone-500 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            <span>2 days</span>
          </div>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs text-stone-500">Starting from</p>
              <p class="text-xl font-raleway font-bold text-primary">$630</p>
            </div>
            <span class="text-primary font-raleway font-semibold group-hover:underline">See more</span>
          </div>
        </div>
      </a>
      
      <a href="/tours/zanzibar-bliss-6-nights-at-upendo-beach" class="group relative overflow-hidden rounded-2xl bg-lighter shadow-lg card-lift">
        <div class="relative overflow-hidden aspect-[16/10]">
          <img src="https://cdn.sanity.io/images/oot9i5yy/production/de59644c4e623071cd0b03605e2e18deac91da5e-1920x1277.jpg" alt="Canoe in Zanzibar" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-raleway font-semibold text-stone-800 mb-2">Zanzibar Bliss: 6 Nights at Upendo Beach</h3>
          <div class="flex items-center gap-2 text-sm text-stone-500 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            <span>6 days</span>
          </div>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs text-stone-500">Starting from</p>
              <p class="text-xl font-raleway font-bold text-primary">$2,180</p>
            </div>
            <span class="text-primary font-raleway font-semibold group-hover:underline">See more</span>
          </div>
        </div>
      </a>
      
      <a href="/tours/tanzania-luxury-safari-and-zanzibar-escape" class="group relative overflow-hidden rounded-2xl bg-lighter shadow-lg card-lift">
        <div class="relative overflow-hidden aspect-[16/10]">
          <img src="https://cdn.sanity.io/images/oot9i5yy/production/91d5c0d149fa714dcd543ba43f735959eecb204c-1920x1080.jpg" alt="Cubs in Tanzania" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
          <span class="absolute top-4 left-4 bg-primary text-white text-xs font-semibold px-3 py-1 rounded-full">Luxury</span>
        </div>
        <div class="p-6">
          <h3 class="text-lg font-raleway font-semibold text-stone-800 mb-2">Tanzania Luxury Safari & Zanzibar Escape</h3>
          <div class="flex items-center gap-2 text-sm text-stone-500 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            <span>14 days</span>
          </div>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs text-stone-500">Starting from</p>
              <p class="text-xl font-raleway font-bold text-primary">$11,780</p>
            </div>
            <span class="text-primary font-raleway font-semibold group-hover:underline">See more</span>
          </div>
        </div>
      </a>
    </div>
    
    <div class="text-center mt-12">
      <a href="/tours" class="btn-outline-primary">See more itineraries</a>
    </div>
  </div>
</section>