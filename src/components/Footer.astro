---
import { getEntry } from 'astro:content';
const site = await getEntry('site', 'settings');
const { footer } = site.data;
---

<footer class="bg-darker text-white">
  <div class="mx-auto max-w-5xl px-4 xl:px-8 py-16">
    <div class="grid gap-12 lg:grid-cols-2 mb-16">
      <div>
        <h3 class="text-2xl font-raleway font-semibold mb-4">{footer.newsletter_heading}</h3>
        <p class="text-stone-400 mb-6">{footer.newsletter_text}</p>
        <form class="flex gap-3">
          <input type="email" placeholder="Email address" class="flex-1 rounded-full bg-white/10 px-6 py-3 text-white placeholder-stone-500 outline-none focus:ring-2 focus:ring-primary transition-colors" />
          <button type="submit" class="rounded-full bg-[#A87133] px-8 py-3 font-raleway font-semibold text-white transition-colors hover:bg-primary/90">{footer.newsletter_button}</button>
        </form>
      </div>
      
      <div>
        <h4 class="text-xl font-raleway font-semibold mb-4">{footer.cta_heading}</h4>
        <p class="text-stone-400 mb-6">{footer.cta_text}</p>
        <a href={footer.cta_button_link} class="inline-block rounded-full bg-[#A87133] px-8 py-3 font-raleway font-semibold text-white transition-colors hover:bg-primary/90">{footer.cta_button}</a>
      </div>
    </div>
    
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4 border-t border-white/10 pt-12">
      <div>
        <h5 class="font-raleway font-semibold text-lg mb-4">Safaris</h5>
        <ul class="space-y-2 text-stone-400">
          <li><a href="/safaris/honeymooners" class="hover:text-primary transition-colors">HoneyMoon Safaris</a></li>
          <li><a href="/safaris/family-safaris" class="hover:text-primary transition-colors">Family Safaris</a></li>
          <li><a href="/safaris/wildlife-adventures" class="hover:text-primary transition-colors">Wildlife and Nature</a></li>
          <li><a href="/safaris/adventure-seekers" class="hover:text-primary transition-colors">Adventure Seekers</a></li>
          <li><a href="/safaris/classic-safaris" class="hover:text-primary transition-colors">Classic Safaris</a></li>
          <li><a href="/safaris/off-beaten-path" class="hover:text-primary transition-colors">Offbeaten Path</a></li>
          <li><a href="/safaris/arushaNationalPark" class="hover:text-primary transition-colors">Best of Tanzania</a></li>
          <li><a href="/safaris/migration-safaris" class="hover:text-primary transition-colors">Migration Safaris</a></li>
          <li><a href="/zanzibar" class="hover:text-primary transition-colors">Beach Holiday</a></li>
        </ul>
      </div>
      
      <div>
        <h5 class="font-raleway font-semibold text-lg mb-4">Mount Kilimanjaro</h5>
        <ul class="space-y-2 text-stone-400">
          <li><a href="/kilimanjaro" class="hover:text-primary transition-colors">Climbing Mount Kilimanjaro</a></li>
          <li><a href="/kilimanjaro/itineraries" class="hover:text-primary transition-colors">Our Kilimanjaro Itineraries</a></li>
          <li><a href="/kilimanjaro/what-makes-kilimanjaro-tazama-trek-different" class="hover:text-primary transition-colors">Tazama's Kilimanjaro Experience</a></li>
          <li><a href="/kilimanjaro/routes" class="hover:text-primary transition-colors">Kilimanjaro Routes</a></li>
          <li><a href="/kilimanjaro/routes/lemosho" class="hover:text-primary transition-colors">Lemosho Route</a></li>
          <li><a href="/kilimanjaro/routes/machame" class="hover:text-primary transition-colors">Machame Route</a></li>
          <li><a href="/kilimanjaro/routes/marangu" class="hover:text-primary transition-colors">Marangu Route</a></li>
        </ul>
      </div>
      
      <div>
        <h5 class="font-raleway font-semibold text-lg mb-4">East Africa</h5>
        <ul class="space-y-2 text-stone-400">
          <li><a href="/east-africa/tanzania" class="hover:text-primary transition-colors">Tanzania</a></li>
          <li><a href="/east-africa/kenya" class="hover:text-primary transition-colors">Kenya</a></li>
          <li><a href="/east-africa/rwanda" class="hover:text-primary transition-colors">Rwanda</a></li>
          <li><a href="/east-africa/uganda" class="hover:text-primary transition-colors">Uganda</a></li>
        </ul>
      </div>
      
      <div>
        <h5 class="font-raleway font-semibold text-lg mb-4">Other Links</h5>
        <ul class="space-y-2 text-stone-400">
          <li><a href="/lodges" class="hover:text-primary transition-colors">Our Itineraries</a></li>
          <li><a href="/lodges" class="hover:text-primary transition-colors">Lodges</a></li>
          <li><a href="/partners" class="hover:text-primary transition-colors">Partners</a></li>
          <li><a href="/sustainability" class="hover:text-primary transition-colors">Sustainability</a></li>
          <li><a href="/terms" class="hover:text-primary transition-colors">Terms & Conditions</a></li>
          <li><a href="/contact" class="hover:text-primary transition-colors">Contact</a></li>
          <li><a href="/blogs" class="hover:text-primary transition-colors">Blog</a></li>
        </ul>
      </div>
    </div>
    
    <div class="mt-12 flex flex-col items-center gap-6 border-t border-white/10 pt-8">
      <p class="text-stone-500 text-sm">{footer.copyright}</p>
      
      <div class="flex gap-6">
        <a href={footer.social.tripadvisor_url} target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-tripadvisor transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
        </a>
        <a href={footer.social.instagram_url} target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-[#C13584] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href={footer.social.facebook_url} target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-[#4267B2] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href={footer.social.youtube_url} target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-[#FF0000] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href={footer.social.tiktok_url} target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>