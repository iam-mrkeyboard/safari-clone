---
import { getCollection } from 'astro:content';
const tours = (await getCollection('tours')).sort(
  (a, b) => a.data.order - b.data.order
);

function formatPrice(price: string) {
  const num = parseInt(price, 10);
  return '$' + num.toLocaleString('en-US');
}
---

<section id="tours" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4 xl:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-raleway font-bold text-stone-800 mb-4">Authentic & Timeless Adventures</h2>
      <p class="text-stone-600 max-w-2xl mx-auto">Start exploring our sample itineraries and see where an adventure with Tazama Africa can take you.</p>
    </div>
    
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {tours.map((tour) => (
        <a href={tour.data.link} class="group relative overflow-hidden rounded-2xl bg-lighter shadow-lg card-lift">
          <div class="relative overflow-hidden aspect-[16/10]">
            <img src={tour.data.image} alt={tour.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" decoding="async" />
            {tour.data.badge && (
              <span class="absolute top-4 left-4 bg-primary text-white text-xs font-semibold px-3 py-1 rounded-full">{tour.data.badge}</span>
            )}
          </div>
          <div class="p-6">
            <h3 class="text-lg font-raleway font-semibold text-stone-800 mb-2">{tour.data.title}</h3>
            <div class="flex items-center gap-2 text-sm text-stone-500 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
              <span>{tour.data.duration}</span>
            </div>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs text-stone-500">Starting from</p>
                <p class="text-xl font-raleway font-bold text-primary">{formatPrice(tour.data.price)}</p>
              </div>
              <span class="text-primary font-raleway font-semibold group-hover:underline">See more</span>
            </div>
          </div>
        </a>
      ))}
    </div>
    
    <div class="text-center mt-12">
      <a href="/tours" class="btn-outline-primary">See more itineraries</a>
    </div>
  </div>
</section>