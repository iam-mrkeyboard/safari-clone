---
---

<section class="relative min-h-screen overflow-hidden">
  <video autoplay muted loop playsinline class="absolute inset-0 h-full w-full object-cover opacity-80">
    <source src="https://res.cloudinary.com/drhl0yu7y/video/upload/v1764753833/tazama-video_ijznqm.mp4" type="video/mp4">
  </video>
  
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
  
  <div class="relative z-10 mx-auto max-w-5xl px-4 xl:px-8 pt-32 pb-20">
    <div class="text-center text-white mb-16">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-raleway font-bold mb-6 text-shadow">Your Next Adventure Awaits</h1>
      <h3 class="text-xl md:text-2xl font-raleway font-light mb-4 text-shadow">connect, celebrate & create memories</h3>
      <h3 class="text-lg md:text-xl font-poppins font-light mb-6 max-w-2xl mx-auto text-shadow">Fulfill your travel dreams with Tazama</h3>
      <p class="text-base md:text-lg font-poppins font-light max-w-3xl mx-auto text-stone-200">Tazama specializes in curating unforgettable memories that will have you reminiscing with your loved ones for years to come. Boasting over 15 years of expertise in the safari industry, we've mastered the art of crafting seamless journeys.</p>
    </div>
    
    <div class="grid gap-6 md:grid-cols-3">
      <a href="/safaris" class="group relative overflow-hidden rounded-2xl aspect-[4/5]">
        <img src="https://images.unsplash.com/photo-1695787841479-614715857c28?q=80&w=870&auto=format&fit=crop" alt="Safaris" class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
          <h3 class="text-2xl font-raleway font-semibold mb-2">Safaris</h3>
          <p class="text-sm text-stone-300 mb-4">Serengeti • Ngorongoro • Tarangire</p>
          <span class="inline-block text-primary font-raleway font-semibold group-hover:underline">Discover more</span>
        </div>
      </a>
      
      <a href="/trekking" class="group relative overflow-hidden rounded-2xl aspect-[4/5]">
        <img src="https://images.pexels.com/photos/2101088/pexels-photo-2101088.jpeg" alt="Trekking" class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
          <h3 class="text-2xl font-raleway font-semibold mb-2">Trekking</h3>
          <p class="text-sm text-stone-300 mb-4">Kilimanjaro • Meru • Gorilla Trekking</p>
          <span class="inline-block text-primary font-raleway font-semibold group-hover:underline">Discover more</span>
        </div>
      </a>
      
      <a href="/zanzibar" class="group relative overflow-hidden rounded-2xl aspect-[4/5]">
        <img src="https://images.unsplash.com/photo-1621583628955-42fbc37bf424?q=80&w=435&auto=format&fit=crop" alt="Beach Holidays" class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
          <h3 class="text-2xl font-raleway font-semibold mb-2">Beach Holidays</h3>
          <p class="text-sm text-stone-300 mb-4">Zanzibar • Spice Island • Stone Town</p>
          <span class="inline-block text-primary font-raleway font-semibold group-hover:underline">Discover more</span>
        </div>
      </a>
    </div>
  </div>
</section>
