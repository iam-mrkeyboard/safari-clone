---
import { Image } from 'astro:assets';
const { section } = Astro.props;
const items = section.items?.sort((a, b) => a.order - b.order) || [];
const marqueePartners = [...items, ...items, ...items, ...items];
---

<section class="bg-lighter py-16 overflow-hidden">
  <div class="mx-auto max-w-5xl px-4 xl:px-8 mb-10">
    <h2 class="text-3xl font-raleway font-bold text-stone-800 text-center mb-4">{section.heading}</h2>
    <p class="text-stone-600 text-center max-w-2xl mx-auto">{section.text}</p>
  </div>
  
  <div class="relative flex overflow-hidden">
    <div class="flex animate-marquee items-center gap-12 md:gap-16">
      {marqueePartners.map((partner) => (
        <a href={partner.link} target={partner.link?.startsWith('http') ? '_blank' : undefined} rel={partner.link?.startsWith('http') ? 'noopener noreferrer' : undefined} class="flex-shrink-0 group">
          <Image src={partner.image} alt={`${partner.name} Logo`} class="h-12 md:h-16 w-auto object-contain opacity-70 group-hover:opacity-100 transition-all duration-300" width={200} height={100} />
        </a>
      ))}
    </div>
  </div>
</section>
