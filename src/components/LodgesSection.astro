---

<section id="lodges" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-5xl px-4 xl:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-raleway font-bold text-stone-800 mb-4">Not Sure Where to Stay?</h2>
      <p class="text-stone-600 max-w-2xl mx-auto">Whether you're looking for a budget-friendly option or a luxurious retreat, we have a range of accommodations that we work with to suit your needs.</p>
    </div>
    
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      <a href="/lodges/zuri-zanzibar-hotel-and-resort" class="group overflow-hidden rounded-2xl bg-lighter shadow-lg transition-shadow hover:shadow-xl">
        <div class="overflow-hidden aspect-[4/3]">
          <img src="/assets/images/gallery/lodges/zuri-zanzibar/zuri-zanzibar-header.webp" alt="Zuri Zanzibar Hotel & Resort" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-raleway font-semibold text-stone-800">Zuri Zanzibar Hotel & Resort</h3>
        </div>
      </a>
      
      <a href="/lodges/siringit-camps" class="group overflow-hidden rounded-2xl bg-lighter shadow-lg transition-shadow hover:shadow-xl">
        <div class="overflow-hidden aspect-[4/3]">
          <img src="https://res.cloudinary.com/drhl0yu7y/image/upload/v1720097340/lodges/siringit-camps/1_jvlzqc.jpg" alt="Siringit Camp" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-raleway font-semibold text-stone-800">Siringit Camp</h3>
        </div>
      </a>
      
      <a href="/lodges/upendo-beach-zanzibar" class="group overflow-hidden rounded-2xl bg-lighter shadow-lg transition-shadow hover:shadow-xl">
        <div class="overflow-hidden aspect-[4/3]">
          <img src="https://res.cloudinary.com/drhl0yu7y/image/upload/v1720099589/lodges/upendo-beach-zanzibar/6_dx1r30.jpg" alt="Upendo Beach Zanzibar" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-raleway font-semibold text-stone-800">Upendo Beach Zanzibar</h3>
        </div>
      </a>
    </div>
    
    <div class="text-center mt-12">
      <a href="/lodges" class="inline-block rounded-full bg-[#A87133] px-8 py-3 font-raleway font-semibold text-white transition-colors hover:bg-primary/90">Find More</a>
    </div>
  </div>
</section>
