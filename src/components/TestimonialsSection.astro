---
import { getCollection, getEntry } from 'astro:content';
const homepageEntry = await getEntry('homepage', 'homepage');
const homepage = homepageEntry.data;
const testimonials = (await getCollection('testimonials')).sort(
  (a, b) => a.data.order - b.data.order
);

const featured = testimonials[0];
const gridTestimonials = testimonials.slice(1);

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
}

function Stars({ rating, size = 18 }: { rating: number; size?: number }) {
  const stars = [];
  for (let i = 0; i < 5; i++) {
    stars.push(
      `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="${i < rating ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>`
    );
  }
  return stars.join('');
}
---

<section class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4 xl:px-8">
    <div class="text-center mb-16">
      <span class="inline-block text-sm font-semibold tracking-widest uppercase text-primary mb-3">Testimonials</span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-raleway font-bold text-stone-800 mb-4">{homepage.testimonials_heading}</h2>
      <p class="text-stone-500 max-w-2xl mx-auto text-base md:text-lg">{homepage.testimonials_text}</p>
    </div>
    
    {featured && (
      <div class="mb-12 lg:mb-16">
        <div class="relative bg-gradient-to-br from-primary/5 to-primary/10 rounded-3xl p-8 md:p-12 border border-primary/10">
          <div class="absolute top-6 right-8 md:top-8 md:right-12 text-primary/10">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          </div>
          <div class="relative flex flex-col md:flex-row gap-8 items-start">
            <div class="flex-shrink-0">
              <img src={featured.data.avatar} alt={featured.data.name} class="h-16 w-16 md:h-20 md:w-20 rounded-full object-cover ring-4 ring-white shadow-lg" loading="lazy" decoding="async" />
            </div>
            <div class="flex-1">
              <div class="flex gap-1 mb-4" set:html={Stars({ rating: featured.data.rating, size: 22 })}></div>
              <blockquote class="text-lg md:text-xl lg:text-2xl font-raleway text-stone-700 leading-relaxed mb-6">"{featured.data.text}"</blockquote>
              <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4">
                <span class="font-raleway font-bold text-stone-800 text-lg">{featured.data.name}</span>
                <span class="text-stone-400">•</span>
                <span class="text-stone-500 text-sm">{formatDate(featured.data.date)} • {featured.data.travel_type}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}
    
    {gridTestimonials.length > 0 && (
      <>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {gridTestimonials.map((t) => (
            <div class="group relative bg-white rounded-2xl p-7 shadow-sm border border-stone-100 hover:shadow-xl hover:border-primary/20 transition-all duration-300 hover:-translate-y-1">
              <div class="absolute top-6 right-6 text-primary/8 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
              </div>
              <div class="flex items-center gap-3 mb-4">
                <img src={t.data.avatar} alt={t.data.name} class="h-11 w-11 rounded-full object-cover ring-2 ring-stone-50" loading="lazy" decoding="async" />
                <div>
                  <h4 class="font-raleway font-semibold text-stone-800 text-sm">{t.data.name}</h4>
                  <p class="text-xs text-stone-400">{formatDate(t.data.date)}</p>
                </div>
              </div>
              <div class="flex gap-0.5 mb-3" set:html={Stars({ rating: t.data.rating, size: 14 })}></div>
              <h3 class="font-raleway font-semibold text-stone-800 mb-2 text-sm">{t.data.title}</h3>
              <p class="text-stone-500 text-sm leading-relaxed line-clamp-4">{t.data.text}</p>
              <div class="mt-4 pt-4 border-t border-stone-100 flex items-center gap-2">
                <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                <span class="text-xs font-medium text-primary">{t.data.travel_type}</span>
              </div>
            </div>
          ))}
        </div>
      </>
    )}
    
    <div class="text-center mt-14">
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="h-px w-12 bg-stone-200"></div>
        <span class="text-stone-400 text-sm font-medium">Verified Reviews</span>
        <div class="h-px w-12 bg-stone-200"></div>
      </div>
      <a href="https://www.tripadvisor.com/Attraction_Review-g6940195-d13368802-Reviews-Tazama_Africa_Tours_and_Safari-Arusha_National_Park_Arusha_Region.html" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-8 py-3.5 bg-primary text-white font-raleway font-semibold rounded-full hover:bg-primary-dark transition-colors duration-200 shadow-lg shadow-primary/20 hover:shadow-xl hover:shadow-primary/30">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        Read More on TripAdvisor
      </a>
    </div>
  </div>
</section>