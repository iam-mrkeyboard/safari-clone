---
---

<section id="categories" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4 xl:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-raleway font-bold text-primary mb-4">Fulfill your travel dreams with Tazama</h2>
      <p class="text-stone-600 max-w-2xl mx-auto">With over 15 years of expertise in the safari industry, we've mastered the art of crafting seamless journeys that create unforgettable memories.</p>
    </div>
    
    <div class="grid gap-8 md:grid-cols-3">
      <a href="/safaris" class="group relative overflow-hidden rounded-2xl aspect-[3/4]">
        <img src="https://www.tazamaafricasafari.com/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1695787841479-614715857c28%3Fq%3D80%26w%3D870%26auto%3Dformat%26fit%3Dcrop&w=1920&q=75" alt="Safaris" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <div class="absolute inset-0 border border-white/20 rounded-2xl m-4"></div>
        <div class="absolute top-0 left-0 right-0 p-8">
          <h3 class="text-2xl font-raleway font-bold text-white mb-2">Safaris</h3>
          <p class="text-sm text-white/80">Serengeti • Ngorongoro • Tarangire</p>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-8">
          <span class="inline-flex items-center gap-2 border border-white text-white px-6 py-3 rounded-full font-raleway font-semibold text-sm transition-all duration-300 group-hover:bg-primary group-hover:border-primary">
            Discover more
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
      </a>
      
      <a href="/trekking" class="group relative overflow-hidden rounded-2xl aspect-[3/4]">
        <img src="https://www.tazamaafricasafari.com/_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F2101088%2Fpexels-photo-2101088.jpeg&w=1920&q=75" alt="Trekking" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <div class="absolute inset-0 border border-white/20 rounded-2xl m-4"></div>
        <div class="absolute top-0 left-0 right-0 p-8">
          <h3 class="text-2xl font-raleway font-bold text-white mb-2">Trekking</h3>
          <p class="text-sm text-white/80">Kilimanjaro • Meru • Gorilla Trekking</p>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-8">
          <span class="inline-flex items-center gap-2 border border-white text-white px-6 py-3 rounded-full font-raleway font-semibold text-sm transition-all duration-300 group-hover:bg-primary group-hover:border-primary">
            Discover more
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
      </a>
      
      <a href="/zanzibar" class="group relative overflow-hidden rounded-2xl aspect-[3/4]">
        <img src="https://www.tazamaafricasafari.com/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1621583628955-42fbc37bf424%3Fq%3D80%26w%3D435%26auto%3Dformat%26fit%3Dcrop&w=1920&q=75" alt="Beach Holidays" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <div class="absolute inset-0 border border-white/20 rounded-2xl m-4"></div>
        <div class="absolute top-0 left-0 right-0 p-8">
          <h3 class="text-2xl font-raleway font-bold text-white mb-2">Beach Holidays</h3>
          <p class="text-sm text-white/80">Zanzibar • Spice Island • Stone Town</p>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-8">
          <span class="inline-flex items-center gap-2 border border-white text-white px-6 py-3 rounded-full font-raleway font-semibold text-sm transition-all duration-300 group-hover:bg-primary group-hover:border-primary">
            Discover more
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
      </a>
    </div>
  </div>
</section>