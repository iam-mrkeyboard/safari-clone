---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getEntry } from 'astro:content';

const site = await getEntry('site', 'settings');
const { contact } = site.data;
---

<Layout title="Contact Us - Tazama Africa Safaris">
  <section class="relative py-32 md:py-40 bg-stone-900 overflow-hidden">
    <div class="absolute inset-0">
      <img src={contact.image} alt="" class="w-full h-full object-cover opacity-30" loading="lazy" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-b from-stone-900/60 via-stone-900/70 to-stone-900"></div>
    </div>
    <div class="relative container mx-auto px-4 text-center">
      <span class="inline-block text-gold text-sm tracking-[0.2em] uppercase mb-4 font-raleway font-semibold text-primary">Get in Touch</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-raleway font-bold text-white mb-4">Let's Start Your Journey</h1>
      <p class="text-lg text-stone-300 max-w-2xl mx-auto">Reach out and our team will craft the perfect African adventure tailored just for you.</p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 max-w-6xl mx-auto">
        <div>
          <h2 class="text-3xl font-raleway font-bold text-stone-800 mb-4">We'd Love to Hear From You</h2>
          <p class="text-stone-600 mb-10">Whether you have a question about our safaris, want to customize an itinerary, or just want to say hello — we're here and ready to help.</p>

          <div class="space-y-8">
            <div class="flex items-start gap-5">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#A87133" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </div>
              <div>
                <h3 class="font-raleway font-semibold text-stone-800 mb-1">General Enquiries</h3>
                <p class="text-stone-600">info@tazamaafricasafari.com</p>
                <p class="text-stone-600">+255 754 922 334</p>
              </div>
            </div>

            <div class="flex items-start gap-5">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#A87133" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </div>
              <div>
                <h3 class="font-raleway font-semibold text-stone-800 mb-1">Office Location</h3>
                <p class="text-stone-600">Arusha, Tanzania</p>
                <p class="text-stone-600">East Africa</p>
              </div>
            </div>

            <div class="flex items-start gap-5">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#A87133" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              </div>
              <div>
                <h3 class="font-raleway font-semibold text-stone-800 mb-1">Reservations</h3>
                <p class="text-stone-600">reservations@tazamaafricasafari.com</p>
                <p class="text-stone-600">+255 744 400 043</p>
              </div>
            </div>

            <div class="flex items-start gap-5">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#A87133" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
              </div>
              <div>
                <h3 class="font-raleway font-semibold text-stone-800 mb-1">Office Hours</h3>
                <p class="text-stone-600">Monday - Friday: 8:00 AM - 5:00 PM</p>
                <p class="text-stone-600">Saturday: 9:00 AM - 1:00 PM</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-lighter rounded-2xl p-6 sm:p-8 md:p-10 shadow-sm">
          <h3 class="text-2xl font-raleway font-bold text-stone-800 mb-6">Send Us a Message</h3>
          <form action="#" method="POST" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-raleway font-semibold text-stone-700 mb-2">Full Name <span class="text-primary">*</span></label>
                <input type="text" id="name" name="name" required class="w-full rounded-xl border border-stone-200 bg-white px-4 py-3 text-stone-800 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" placeholder="Your name" />
              </div>
              <div>
                <label for="email" class="block text-sm font-raleway font-semibold text-stone-700 mb-2">Email <span class="text-primary">*</span></label>
                <input type="email" id="email" name="email" required class="w-full rounded-xl border border-stone-200 bg-white px-4 py-3 text-stone-800 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" placeholder="your@email.com" />
              </div>
            </div>
            <div>
              <label for="subject" class="block text-sm font-raleway font-semibold text-stone-700 mb-2">Subject</label>
              <input type="text" id="subject" name="subject" class="w-full rounded-xl border border-stone-200 bg-white px-4 py-3 text-stone-800 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" placeholder="How can we help?" />
            </div>
            <div>
              <label for="message" class="block text-sm font-raleway font-semibold text-stone-700 mb-2">Message <span class="text-primary">*</span></label>
              <textarea id="message" name="message" rows="5" required class="w-full rounded-xl border border-stone-200 bg-white px-4 py-3 text-stone-800 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors resize-none" placeholder="Tell us about your dream safari..."></textarea>
            </div>
            <button type="submit" class="w-full rounded-full bg-primary px-8 py-3 font-raleway font-semibold text-white transition-all hover:bg-primary/90 hover:shadow-lg">
              Send Message
            </button>
            <p class="text-xs text-stone-400 text-center">We respect your privacy and never share your details.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-20 bg-stone-900 overflow-hidden">
    <div class="absolute inset-0">
      <img src={contact.image} alt="" class="w-full h-full object-cover opacity-20" loading="lazy" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-stone-900/80 to-stone-900/60"></div>
    </div>
    <div class="relative container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-raleway font-bold text-white mb-4">{contact.heading}</h2>
      <p class="text-stone-300 max-w-2xl mx-auto mb-8">{contact.tagline}</p>
      <a href="/tours" class="inline-block w-full sm:w-auto text-center rounded-full bg-primary px-8 py-3 font-raleway font-semibold text-white transition-all hover:bg-primary/90 hover:shadow-lg">Explore Tours</a>
      <a href="https://wa.me/255754922334" target="_blank" rel="noopener noreferrer" class="inline-block w-full sm:w-auto text-center rounded-full border-2 border-white/30 text-white px-8 py-3 font-raleway font-semibold transition-all hover:bg-white/10 hover:border-white/50">Chat on WhatsApp</a>
    </div>
  </section>
</Layout>