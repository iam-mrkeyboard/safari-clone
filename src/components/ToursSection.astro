---
---

<section id="tours" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-5xl px-4 xl:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-raleway font-bold text-stone-800 mb-4">Authentic & timeless adventures</h2>
      <p class="text-stone-600 max-w-2xl mx-auto">Start exploring some of our sample itineraries and see where an adventure with Tazama Africa can take you.</p>
    </div>
    
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      <a href="/tours/2-day-tarangire-and-ngorongoro-safari" class="group overflow-hidden rounded-2xl bg-lighter shadow-lg transition-shadow hover:shadow-xl">
        <div class="overflow-hidden aspect-[16/10]">
          <img src="https://cdn.sanity.io/images/oot9i5yy/production/5330544f7ebacf5cc451a5ad3d1b9f2e2c241fa7-1920x1080.jpg" alt="Baobab tree in Tarangire" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-raleway font-semibold text-stone-800 mb-2">2-Day Tarangire & Ngorongoro Safari</h3>
          <p class="text-sm text-stone-500 mb-3">2 days</p>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs text-stone-500">Starting from</p>
              <p class="text-xl font-raleway font-bold text-primary">$630</p>
            </div>
            <span class="text-primary font-raleway font-semibold group-hover:underline">See more</span>
          </div>
        </div>
      </a>
      
      <a href="/tours/zanzibar-bliss-6-nights-at-upendo-beach" class="group overflow-hidden rounded-2xl bg-lighter shadow-lg transition-shadow hover:shadow-xl">
        <div class="overflow-hidden aspect-[16/10]">
          <img src="https://cdn.sanity.io/images/oot9i5yy/production/de59644c4e623071cd0b03605e2e18deac91da5e-1920x1277.jpg" alt="Canoe in Zanzibar" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-raleway font-semibold text-stone-800 mb-2">Zanzibar Bliss: 6 Nights at Upendo Beach</h3>
          <p class="text-sm text-stone-500 mb-3">6 days</p>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs text-stone-500">Starting from</p>
              <p class="text-xl font-raleway font-bold text-primary">$2,180</p>
            </div>
            <span class="text-primary font-raleway font-semibold group-hover:underline">See more</span>
          </div>
        </div>
      </a>
      
      <a href="/tours/tanzania-luxury-safari-and-zanzibar-escape" class="group overflow-hidden rounded-2xl bg-lighter shadow-lg transition-shadow hover:shadow-xl">
        <div class="overflow-hidden aspect-[16/10]">
          <img src="https://cdn.sanity.io/images/oot9i5yy/production/91d5c0d149fa714dcd543ba43f735959eecb204c-1920x1080.jpg" alt="Cubs in Tanzania" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-raleway font-semibold text-stone-800 mb-2">Tanzania Luxury Safari & Zanzibar Escape</h3>
          <p class="text-sm text-stone-500 mb-3">14 days</p>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs text-stone-500">Starting from</p>
              <p class="text-xl font-raleway font-bold text-primary">$11,780</p>
            </div>
            <span class="text-primary font-raleway font-semibold group-hover:underline">See more</span>
          </div>
        </div>
      </a>
    </div>
    
    <div class="text-center mt-12">
      <a href="/tours" class="inline-block rounded-full bg-[#A87133] px-8 py-3 font-raleway font-semibold text-white transition-colors hover:bg-primary/90">See more itineraries</a>
    </div>
  </div>
</section>
