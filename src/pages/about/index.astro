---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'about');
const { hero_image, hero_tagline, hero_title, hero_description, story_tagline, story_heading, story_description, story_paragraphs, story_image, values_heading, values_description, values, stats, cta_heading, cta_description, cta_buttons } = page.data;

const valueIcons = [
  '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 22L9 15M9 15L12 20L22 2L15 12L9 15Z"/><path d="M7 17L4 20"/></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>',
];
const statIcons = [
  '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>',
];
---

<Layout title="About Us - Tazama Africa Safaris">
  <section class="relative py-32 md:py-40 bg-stone-900 overflow-hidden">
    <div class="absolute inset-0">
      <img src={hero_image} alt="" class="w-full h-full object-cover opacity-40" loading="lazy" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-b from-stone-900/70 via-stone-900/60 to-stone-900"></div>
    </div>
    <div class="relative container mx-auto px-4 text-center">
      <span class="inline-block text-primary text-sm tracking-[0.2em] uppercase mb-4 font-raleway font-semibold">{hero_tagline}</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-raleway font-bold text-white mb-4">{hero_title}</h1>
      <p class="text-lg text-stone-300 max-w-2xl mx-auto">{hero_description}</p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-primary text-sm tracking-[0.2em] uppercase font-raleway font-semibold mb-3 block">{story_tagline}</span>
          <h2 class="text-3xl md:text-4xl font-raleway font-bold text-stone-800 mb-6">{story_heading}</h2>
          <div class="space-y-4 text-stone-600 leading-relaxed">
            <p>{story_description}</p>
            {story_paragraphs?.map((p) => <p>{p}</p>)}
          </div>
        </div>
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-xl">
            <img src={story_image} alt="Tazama Africa Safari" class="w-full h-auto object-cover" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-6 -left-6 bg-primary text-white rounded-2xl p-6 shadow-lg shadow-primary/25 hidden lg:block">
            <p class="text-3xl font-raleway font-bold">15+</p>
            <p class="text-sm text-white/80">Years of Excellence</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-lighter">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6 max-w-4xl mx-auto">
        {stats?.map((stat, i) => (
          <div class="text-center p-6 rounded-2xl bg-white shadow-sm card-lift">
            <p class="text-3xl md:text-4xl font-raleway font-bold text-primary mb-1">{stat.value}</p>
            <p class="text-sm text-stone-500">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-16">
        <span class="text-primary text-sm tracking-[0.2em] uppercase font-raleway font-semibold mb-3 block">Our Approach</span>
        <h2 class="text-3xl md:text-4xl font-raleway font-bold text-stone-800 mb-4">{values_heading}</h2>
        <p class="text-stone-600 max-w-2xl mx-auto">{values_description}</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {values?.map((value, i) => (
          <div class="p-8 rounded-2xl bg-lighter border border-stone-100 card-lift">
            <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mb-5" set:html={valueIcons[i] || valueIcons[0]}></div>
            <h3 class="text-xl font-raleway font-bold text-stone-800 mb-3">{value.title}</h3>
            <p class="text-stone-600 leading-relaxed">{value.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {cta_heading && (
    <section class="relative py-20 bg-stone-900 overflow-hidden">
      <div class="absolute inset-0">
        <img src={story_image} alt="" class="w-full h-full object-cover opacity-20" loading="lazy" decoding="async" />
        <div class="absolute inset-0 bg-gradient-to-r from-stone-900/80 to-stone-900/60"></div>
      </div>
      <div class="relative container mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-4xl font-raleway font-bold text-white mb-4">{cta_heading}</h2>
        <p class="text-stone-300 max-w-2xl mx-auto mb-8">{cta_description}</p>
        <div class="flex flex-wrap justify-center gap-4">
          {cta_buttons?.map((btn) => (
            <a href={btn.link} class={btn.style === 'primary'
              ? 'inline-block rounded-full bg-primary px-8 py-3 font-raleway font-semibold text-white transition-all hover:bg-primary-dark hover:shadow-lg'
              : 'inline-block rounded-full border-2 border-white/30 text-white px-8 py-3 font-raleway font-semibold transition-all hover:bg-white/10 hover:border-white/50'
            }>{btn.text}</a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
