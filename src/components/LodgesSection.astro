---
import { getCollection } from 'astro:content';
const lodges = (await getCollection('lodges')).sort(
  (a, b) => a.data.order - b.data.order
);

function Stars({ rating }: { rating: number }) {
  const stars = [];
  for (let i = 0; i < 5; i++) {
    const fill = i < rating ? '#A87133' : 'none';
    stars.push(
      `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="${fill}" stroke="#A87133" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>`
    );
  }
  return stars.join('');
}
---

<section id="lodges" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4 xl:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-raleway font-bold text-stone-800 mb-4">Not Sure Where to Stay?</h2>
      <p class="text-stone-600 max-w-2xl mx-auto">Whether you're looking for a budget-friendly option or a luxurious retreat, we have a range of accommodations to suit your needs.</p>
    </div>
    
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {lodges.map((lodge) => (
        <a href={lodge.data.link} class="group overflow-hidden rounded-2xl bg-lighter shadow-lg card-lift">
          <div class="relative overflow-hidden aspect-[4/3]">
            <img src={lodge.data.image} alt={lodge.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" decoding="async" />
            <span class="absolute top-4 right-4 text-white text-xs font-semibold px-3 py-1 rounded-full" class:list={lodge.data.tag === 'Luxury' ? 'bg-primary' : 'bg-stone-600'}>{lodge.data.tag}</span>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-raleway font-semibold text-stone-800">{lodge.data.title}</h3>
            <div class="flex items-center gap-1 mt-2" set:html={Stars({ rating: lodge.data.rating })}></div>
          </div>
        </a>
      ))}
    </div>
    
    <div class="text-center mt-12">
      <a href="/lodges" class="btn-outline-primary">Find More</a>
    </div>
  </div>
</section>