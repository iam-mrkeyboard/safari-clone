---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'contact');
const { hero_image, hero_tagline, hero_title, hero_description, contact_heading, contact_description, offices, form_heading, form_name_label, form_email_label, form_subject_label, form_message_label, form_submit_text, form_privacy_text, cta_heading, cta_description, cta_buttons } = page.data;

const officeIcons = [
  '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>',
  '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>',
];
---

<Layout title="Contact Us - Tazama Africa Safaris">
  <section class="relative py-32 md:py-40 bg-stone-900 overflow-hidden">
    <div class="absolute inset-0">
      <img src={hero_image} alt="" class="w-full h-full object-cover opacity-30" loading="lazy" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-b from-stone-900/60 via-stone-900/70 to-stone-900"></div>
    </div>
    <div class="relative container mx-auto px-4 text-center">
      <span class="inline-block text-primary text-sm tracking-[0.2em] uppercase mb-4 font-raleway font-semibold">{hero_tagline}</span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-raleway font-bold text-white mb-4">{hero_title}</h1>
      <p class="text-lg text-stone-300 max-w-2xl mx-auto">{hero_description}</p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 max-w-6xl mx-auto">
        <div>
          <h2 class="text-3xl font-raleway font-bold text-stone-800 mb-4">{contact_heading}</h2>
          <p class="text-stone-600 mb-10">{contact_description}</p>

          <div class="space-y-8">
            {offices?.map((office, i) => (
              <div class="flex items-start gap-5">
                <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-1" set:html={officeIcons[i] || officeIcons[0]}></div>
                <div>
                  <h3 class="font-raleway font-semibold text-stone-800 mb-1">{office.title}</h3>
                  {office.email && <p class="text-stone-600">{office.email}</p>}
                  {office.phone && <p class="text-stone-600">{office.phone}</p>}
                  {office.address_line1 && <p class="text-stone-600">{office.address_line1}</p>}
                  {office.address_line2 && <p class="text-stone-600">{office.address_line2}</p>}
                  {office.hours_line1 && <p class="text-stone-600">{office.hours_line1}</p>}
                  {office.hours_line2 && <p class="text-stone-600">{office.hours_line2}</p>}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-lighter rounded-2xl p-6 sm:p-8 md:p-10 shadow-sm">
          <h3 class="text-2xl font-raleway font-bold text-stone-800 mb-6">{form_heading}</h3>
          <form action="#" method="POST" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-raleway font-semibold text-stone-700 mb-2">{form_name_label} <span class="text-primary">*</span></label>
                <input type="text" id="name" name="name" required class="w-full rounded-xl border border-stone-200 bg-white px-4 py-3 text-stone-800 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" placeholder="Your name" />
              </div>
              <div>
                <label for="email" class="block text-sm font-raleway font-semibold text-stone-700 mb-2">{form_email_label} <span class="text-primary">*</span></label>
                <input type="email" id="email" name="email" required class="w-full rounded-xl border border-stone-200 bg-white px-4 py-3 text-stone-800 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" placeholder="your@email.com" />
              </div>
            </div>
            <div>
              <label for="subject" class="block text-sm font-raleway font-semibold text-stone-700 mb-2">{form_subject_label}</label>
              <input type="text" id="subject" name="subject" class="w-full rounded-xl border border-stone-200 bg-white px-4 py-3 text-stone-800 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors" placeholder="How can we help?" />
            </div>
            <div>
              <label for="message" class="block text-sm font-raleway font-semibold text-stone-700 mb-2">{form_message_label} <span class="text-primary">*</span></label>
              <textarea id="message" name="message" rows="5" required class="w-full rounded-xl border border-stone-200 bg-white px-4 py-3 text-stone-800 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors resize-none" placeholder="Tell us about your dream safari..."></textarea>
            </div>
            <button type="submit" class="w-full rounded-full bg-primary px-8 py-3 font-raleway font-semibold text-white transition-all hover:bg-primary-dark hover:shadow-lg">
              {form_submit_text}
            </button>
            <p class="text-xs text-stone-400 text-center">{form_privacy_text}</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  {cta_heading && (
    <section class="relative py-20 bg-stone-900 overflow-hidden">
      <div class="absolute inset-0">
        <img src={hero_image} alt="" class="w-full h-full object-cover opacity-20" loading="lazy" decoding="async" />
        <div class="absolute inset-0 bg-gradient-to-r from-stone-900/80 to-stone-900/60"></div>
      </div>
      <div class="relative container mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-4xl font-raleway font-bold text-white mb-4">{cta_heading}</h2>
        <p class="text-stone-300 max-w-2xl mx-auto mb-8">{cta_description}</p>
        <div class="flex flex-wrap justify-center gap-4">
          {cta_buttons?.map((btn) => (
            <a href={btn.link} class={btn.style === 'primary'
              ? 'inline-block rounded-full bg-primary px-8 py-3 font-raleway font-semibold text-white transition-all hover:bg-primary-dark hover:shadow-lg'
              : 'inline-block rounded-full border-2 border-white/30 text-white px-8 py-3 font-raleway font-semibold transition-all hover:bg-white/10 hover:border-white/50'
            } target={btn.link.startsWith('http') ? '_blank' : undefined} rel={btn.link.startsWith('http') ? 'noopener noreferrer' : undefined}>{btn.text}</a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
