---
import { getCollection } from 'astro:content';
const testimonials = (await getCollection('testimonials')).sort(
  (a, b) => a.data.order - b.data.order
);

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
}

function Stars({ rating }: { rating: number }) {
  const stars = [];
  for (let i = 0; i < 5; i++) {
    stars.push(
      `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="${i < rating ? '#A87133' : 'none'}" stroke="#A87133" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>`
    );
  }
  return stars.join('');
}
---

<section class="bg-lighter py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4 xl:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-raleway font-bold text-stone-800 mb-4">Join Our Many Satisfied Customers</h2>
    </div>
    
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <div class="rounded-2xl bg-tripadvisorLight p-8 shadow-lg card-lift">
          <div class="flex items-center gap-4 mb-4">
            <img src={t.data.avatar} alt={t.data.name} class="h-12 w-12 rounded-full object-cover" />
            <div>
              <h4 class="font-raleway font-semibold text-stone-800">{t.data.name}</h4>
            </div>
          </div>
          <div class="flex gap-1 mb-3" set:html={Stars({ rating: t.data.rating })}></div>
          <h3 class="font-raleway font-semibold text-stone-800 mb-2">{t.data.title}</h3>
          <p class="text-sm text-stone-500 mb-4">{formatDate(t.data.date)} • {t.data.travel_type}</p>
          <p class="text-stone-600 text-sm leading-relaxed">{t.data.text}</p>
        </div>
      ))}
    </div>
    
    <div class="text-center mt-12">
      <a href="https://www.tripadvisor.com/Attraction_Review-g6940195-d13368802-Reviews-Tazama_Africa_Tours_and_Safari-Arusha_National_Park_Arusha_Region.html" target="_blank" rel="noopener noreferrer" class="btn-outline-primary">See more of our reviews</a>
    </div>
  </div>
</section>