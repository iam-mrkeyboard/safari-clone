---
import { getCollection } from 'astro:content';
const destinations = (await getCollection('destinations')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="destinations" class="bg-dark py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4 xl:px-8">
    <div class="text-center text-white mb-16">
      <h2 class="text-3xl md:text-4xl font-raleway font-bold mb-6">Explore East Africa, The Tazama Way</h2>
      <p class="text-stone-400 max-w-2xl mx-auto">Our expertise spans all four corners of East Africa. Whether you're tracking gorillas, chasing the Great Migration, or unwinding on pristine coastlines, Tazama crafts fully personalized itineraries shaped around you.</p>
      <p class="text-stone-400 mt-4">Click on any destination below and begin your journey.</p>
    </div>
    
    <div class="grid grid-cols-2 gap-5 md:gap-8">
      {destinations.map((dest) => (
        <a href={dest.data.link} class="group relative overflow-hidden rounded-2xl aspect-[4/3]">
          <img src={dest.data.image} alt={dest.data.title} class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <h3 class="text-2xl md:text-3xl font-raleway font-bold text-white mb-1">{dest.data.title}</h3>
            <span class="text-primary text-xs font-raleway font-semibold opacity-0 group-hover:opacity-100 transition-opacity duration-300">Discover more →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>