---
---

<section id="categories" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4 xl:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-raleway font-bold text-primary mb-4">Fulfill your travel dreams with Tazama</h2>
      <p class="text-stone-600 max-w-2xl mx-auto">With over 15 years of expertise in the safari industry, we've mastered the art of crafting seamless journeys that create unforgettable memories.</p>
    </div>
    
    <div class="grid gap-6 md:grid-cols-3">
      <a href="/safaris" class="group relative overflow-hidden rounded-2xl aspect-[3/4] card-lift">
        <img src="https://images.unsplash.com/photo-1695787841479-614715857c28?q=80&w=870&auto=format&fit=crop" alt="Safaris" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute top-0 left-0 right-0 p-6">
          <h3 class="text-2xl font-raleway font-bold text-white">Safaris</h3>
          <p class="text-sm text-white/80 mt-1">Serengeti • Ngorongoro • Tarangire</p>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <span class="btn-outline-gold">Discover more</span>
        </div>
      </a>
      
      <a href="/trekking" class="group relative overflow-hidden rounded-2xl aspect-[3/4] card-lift">
        <img src="https://images.pexels.com/photos/2101088/pexels-photo-2101088.jpeg" alt="Trekking" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute top-0 left-0 right-0 p-6">
          <h3 class="text-2xl font-raleway font-bold text-white">Trekking</h3>
          <p class="text-sm text-white/80 mt-1">Kilimanjaro • Meru • Gorilla Trekking</p>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <span class="btn-outline-gold">Discover more</span>
        </div>
      </a>
      
      <a href="/zanzibar" class="group relative overflow-hidden rounded-2xl aspect-[3/4] card-lift">
        <img src="https://images.unsplash.com/photo-1621583628955-42fbc37bf424?q=80&w=435&auto=format&fit=crop" alt="Beach Holidays" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute top-0 left-0 right-0 p-6">
          <h3 class="text-2xl font-raleway font-bold text-white">Beach Holidays</h3>
          <p class="text-sm text-white/80 mt-1">Zanzibar • Spice Island • Stone Town</p>
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <span class="btn-outline-gold">Discover more</span>
        </div>
      </a>
    </div>
  </div>
</section>