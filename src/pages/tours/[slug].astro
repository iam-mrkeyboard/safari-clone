---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const tours = await getCollection('tours');
  return tours.map((tour) => {
    const slug = tour.data.link.replace('/tours/', '');
    return {
      params: { slug },
      props: { tour },
    };
  });
}

const { tour } = Astro.props;
const body = tour.body;

function parseTourContent(content: string) {
  const sections = content.split(/\n## /);
  const result: Record<string, string> = {};
  sections.forEach((section, i) => {
    if (i === 0) {
      result.intro = section.trim();
      return;
    }
    const headingMatch = section.match(/^([^\n]+)/);
    const contentMatch = section.match(/\n([\s\S]*)/);
    if (headingMatch) {
      const heading = headingMatch[1].trim();
      const body = contentMatch ? contentMatch[1].trim() : '';
      result[heading] = body;
    }
  });
  return result;
}

const sections = parseTourContent(body);
const intro = sections.intro || '';
const itinerary = sections['Itinerary'] || '';
const pricing = sections['Pricing'] || '';
const costIncludes = sections['Cost Includes'] || '';
const costExcludes = sections['Cost Excludes'] || '';

function parseItinerary(content: string) {
  const days = content.split(/### Day /).filter(Boolean);
  return days.map(day => {
    const match = day.match(/^(\d+):\s*(.*?)(?=\n\n|\n\*\*|$)/s);
    if (!match) return { day: '', title: '', description: '', highlights: '', accommodation: '', meals: '' };
    const dayNum = match[1];
    const title = match[2] ? match[2].trim() : '';
    const rest = day.slice(match[0].length).trim();
    const highlights = rest.match(/\*\*Highlights:\*\*\s*(.*?)(?=\n\n|\n\*\*|$)/s);
    const accommodation = rest.match(/\*\*Accommodation:\*\*\s*(.*?)(?=\n|$)/s);
    const meals = rest.match(/\*\*Meal Plan:\*\*\s*(.*?)(?=\n\n|\n\*\*|$)/s);
    const description = rest
      .replace(/\*\*Highlights:\*\*[\s\S]*/g, '')
      .replace(/\*\*Accommodation:\*\*[\s\S]*/g, '')
      .replace(/\*\*Meal Plan:\*\*[\s\S]*/g, '')
      .trim();
    return {
      day: dayNum,
      title,
      description,
      highlights: highlights ? highlights[1].trim() : '',
      accommodation: accommodation ? accommodation[1].trim() : '',
      meals: meals ? meals[1].trim() : '',
    };
  });
}

function parsePricing(content: string) {
  const lines = content.split('\n').filter(line => line.trim() && line.includes('|'));
  return lines.slice(2).map(line => {
    const parts = line.split('|').map(p => p.trim()).filter(Boolean);
    if (parts.length >= 2) return { group: parts[0], price: parts[1] };
    return null;
  }).filter(Boolean) as { group: string; price: string }[];
}

function parseList(content: string) {
  return content.split('\n')
    .filter(line => line.trim().startsWith('- '))
    .map(line => line.replace(/^- /, '').trim());
}

const itineraryDays = parseItinerary(itinerary);
const pricingTable = parsePricing(pricing);
const includesList = parseList(costIncludes);
const excludesList = parseList(costExcludes);
const priceFormatted = '$' + parseFloat(tour.data.price).toLocaleString('en-US', { minimumFractionDigits: parseFloat(tour.data.price) % 1 === 0 ? 0 : 2 });
const whatsappUrl = 'https://wa.me/255754922334?text=I\'m interested in ' + encodeURIComponent(tour.data.title);
---

<Layout title={tour.data.title + ' - Tazama Africa Safari'}>
  <section class="relative h-[50vh] md:h-[60vh] overflow-hidden">
    <img src={tour.data.image} alt={tour.data.title} class="w-full h-full object-cover" loading="lazy" decoding="async" />
    <div class="absolute inset-0 bg-gradient-to-t from-stone-900 via-stone-900/40 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 pb-8">
      <div class="container mx-auto px-4">
        <a href="/tours" class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
          All Tours
        </a>
        <div class="flex items-center gap-3 mb-4">
          {tour.data.badge && (
            <span class="bg-primary text-white text-xs font-semibold px-3 py-1 rounded-full">{tour.data.badge}</span>
          )}
          <span class="bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full backdrop-blur-sm">{tour.data.category}</span>
        </div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-raleway font-bold text-white max-w-4xl">{tour.data.title}</h1>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          {intro && (
            <div class="mb-12">
              <p class="text-lg text-stone-600 leading-relaxed">{intro}</p>
            </div>
          )}

          {itineraryDays.length > 0 && (
            <div class="mb-12">
              <h2 class="text-2xl md:text-3xl font-raleway font-bold text-stone-800 mb-8 flex items-center gap-3">
                <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                Detailed Itinerary
              </h2>
              <div class="space-y-2">
                {itineraryDays.map((day) => (
                  <div class="relative pl-8 md:pl-12 pb-10 last:pb-0 border-l-2 border-primary/20 last:border-transparent">
                    <div class="absolute -left-3 top-0 w-6 h-6 rounded-full bg-primary text-white flex items-center justify-center text-sm font-bold">{day.day}</div>
                    <h3 class="text-xl font-raleway font-bold text-stone-800 mb-3">{day.title}</h3>
                    {day.description && <p class="text-stone-600 mb-4 leading-relaxed">{day.description}</p>}
                    {day.highlights && (
                      <div class="bg-amber-50 border-l-4 border-primary p-4 mb-4">
                        <p class="text-sm text-stone-700"><span class="font-semibold text-primary">Highlights:</span> {day.highlights}</p>
                      </div>
                    )}
                    <div class="flex flex-wrap gap-4 text-sm">
                      {day.accommodation && (
                        <div class="bg-stone-50 rounded-lg px-4 py-2"><span class="text-stone-500">Accommodation:</span> <span class="font-semibold text-stone-800">{day.accommodation}</span></div>
                      )}
                      {day.meals && (
                        <div class="bg-stone-50 rounded-lg px-4 py-2"><span class="text-stone-500">Meals:</span> <span class="font-semibold text-stone-800">{day.meals}</span></div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {(includesList.length > 0 || excludesList.length > 0) && (
            <div class="grid md:grid-cols-2 gap-8 mb-12">
              {includesList.length > 0 && (
                <div class="bg-green-50 rounded-2xl p-6 md:p-8">
                  <h3 class="text-xl font-raleway font-bold text-green-800 mb-6 flex items-center gap-2">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                    Cost Includes
                  </h3>
                  <ul class="space-y-3">
                    {includesList.map((item) => (
                      <li class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                        <span class="text-stone-700">{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {excludesList.length > 0 && (
                <div class="bg-red-50 rounded-2xl p-6 md:p-8">
                  <h3 class="text-xl font-raleway font-bold text-red-800 mb-6 flex items-center gap-2">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg>
                    Cost Excludes
                  </h3>
                  <ul class="space-y-3">
                    {excludesList.map((item) => (
                      <li class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-red-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                        <span class="text-stone-700">{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          )}
        </div>

        <div class="lg:col-span-1">
          <div class="sticky top-8 bg-white rounded-2xl shadow-xl border border-stone-100 p-6 md:p-8">
            <div class="text-center mb-6">
              <p class="text-sm text-stone-500 mb-1">Starting from</p>
              <p class="text-4xl font-raleway font-bold text-primary">{priceFormatted}</p>
              <p class="text-sm text-stone-500">per person</p>
            </div>

            <div class="space-y-4 mb-8">
              <div class="flex items-center gap-3 p-3 bg-stone-50 rounded-lg">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                <div>
                  <p class="text-xs text-stone-500">Duration</p>
                  <p class="font-semibold text-stone-800">{tour.data.duration}</p>
                </div>
              </div>
              <div class="flex items-center gap-3 p-3 bg-stone-50 rounded-lg">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <div>
                  <p class="text-xs text-stone-500">Category</p>
                  <p class="font-semibold text-stone-800">{tour.data.category}</p>
                </div>
              </div>
            </div>

            {pricingTable.length > 0 && (
              <div class="mb-8">
                <h3 class="text-lg font-raleway font-bold text-stone-800 mb-4">Group Pricing</h3>
                <div class="space-y-2">
                  {pricingTable.map((row) => (
                    <div class="flex justify-between items-center p-3 bg-stone-50 rounded-lg">
                      <span class="text-stone-600">{row.group}</span>
                      <span class="font-bold text-primary">{row.price}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            <div class="space-y-3">
              <a href="/contact" class="block w-full text-center rounded-full bg-primary px-6 py-3 font-raleway font-semibold text-white transition-all hover:bg-primary/90 hover:shadow-lg">Enquire Now</a>
              <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="block w-full text-center rounded-full border-2 border-green-600 text-green-600 px-6 py-3 font-raleway font-semibold transition-all hover:bg-green-600 hover:text-white">Chat on WhatsApp</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-r from-stone-900 to-stone-800">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-raleway font-bold text-white mb-4">Ready to Adventure?</h2>
      <p class="text-stone-300 mb-8 max-w-2xl mx-auto">Looking for a getaway where luxury meets nature? Relax in exclusive lodges, savor world-class cuisine, and experience the beauty of untouched landscapes with tailored comfort.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/safaris" class="inline-block rounded-full bg-primary px-8 py-3 font-raleway font-semibold text-white transition-all hover:bg-primary/90 hover:shadow-lg">Explore More</a>
        <a href="/contact" class="inline-block rounded-full border-2 border-white text-white px-8 py-3 font-raleway font-semibold transition-all hover:bg-white hover:text-stone-900">Plan My Trip</a>
      </div>
    </div>
  </section>
</Layout>
