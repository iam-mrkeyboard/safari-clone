---
import { getCollection } from 'astro:content';
const partners = (await getCollection('partners')).sort(
  (a, b) => a.data.order - b.data.order
);
const marqueePartners = [...partners, ...partners];
---

<section class="bg-lighter py-16 overflow-hidden">
  <div class="mx-auto max-w-5xl px-4 xl:px-8 mb-8">
    <h2 class="text-3xl font-raleway font-bold text-stone-800 text-center mb-4">Our Partners</h2>
    <p class="text-stone-600 text-center max-w-2xl mx-auto">We pride ourselves on collaborating with top-tier partners to ensure our guests receive the best experiences Africa has to offer.</p>
  </div>
  
  <div class="relative flex overflow-hidden">
    <div class="flex animate-marquee items-center gap-8">
      {marqueePartners.map((partner) => (
        <a href={partner.data.link} target={partner.data.link.startsWith('http') ? '_blank' : undefined} rel={partner.data.link.startsWith('http') ? 'noopener noreferrer' : undefined} class="flex-shrink-0">
          <img src={partner.data.image} alt={`${partner.data.name} Logo`} class="h-16 w-auto opacity-50 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300" loading="lazy" decoding="async" />
        </a>
      ))}
    </div>
  </div>
</section>